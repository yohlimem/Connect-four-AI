    "import numpy as np\\n",
    "import torch\\n",
    "import random\\n",
    "import time\\n",
    "from tqdm import tqdm\\n",
    "import matplotlib.pyplot as plt\\n",
    "import seaborn as sns\\n",
    "from sklearn.metrics import confusion_matrix, accuracy_score\\n",
    "\\n",
    "from connect4 import Connect4Env\\n",
    "from utils import preprocess_board\\n",
    "from AlphaBetaBot import AlphaBetaBot, SolvedBot as AlphaBetaSolvedBot\\n",
    "from SolvedBot import SolvedBot\\n",
    "from policy import Policy\\n",
    "\\n",
    "class PolicyBot:\\n",
    "    def __init__(self, model_path):\\n",
    "        self.policy = Policy(7, input_channels=2, board_height=6, board_width=7, conv_layers_channels=[32, 64, 32], fc_layer_sizes=[256, 256, 256])\\n",
    "        self.policy.load_from_file(model_path)\\n",
    "        self.policy.eval()\\n",
    "\\n",
    "    def get_action(self, board, piece):\\n",
    "        ai_input = torch.from_numpy(preprocess_board(board, piece)).float().unsqueeze(0)\\n",
    "        with torch.no_grad():\\n",
    "            logits = self.policy.forward(ai_input)[0]\\n",
    "            mask = torch.tensor([0.0 if board[0][c] == 0 else -1e9 for c in range(7)])\\n",
    "            action = torch.argmax(logits + mask).item()\\n",
    "        return action\\n",
    "\\n",
    "def generate_random_state(n_moves):\\n",
    "    env = Connect4Env()\\n",
    "    obs, _ = env.reset()\\n",
    "    done = False\\n",
    "    move_sequence = []\\n",
    "    for _ in range(n_moves):\\n",
    "        if done:\\n",
    "            break\\n",
    "        legal_moves = [c for c in range(env.cols) if env.board[0][c] == 0]\\n",
    "        if not legal_moves:\\n",
    "            break\\n",
    "        action = random.choice(legal_moves)\\n",
    "        obs, _, done, _, _ = env.step(action)\\n",
    "        move_sequence.append(str(action + 1))\\n",
    "    return obs, env.current_player, \\"\\".join(move_sequence)\\n",
    "\\n",
    "def run_benchmark():\\n",
    "    # 1. Initialize Bots\\n",
    "    solved_bot = SolvedBot()\\n",
    "    ab_bot = AlphaBetaBot(depth=4)\\n",
    "    ab_solved_bot = AlphaBetaSolvedBot()\\n",
    "    policy_bot = PolicyBot('This bot is super good large CNN.pth')\\n",
    "\\n",
    "    bots = {\\"AlphaBetaBot\\": ab_bot, \\"AlphaBetaSolvedBot\\": ab_solved_bot, \\"PolicyBot\\": policy_bot}\\n",
    "    results = {name: [] for name in bots.keys()}\\n",
    "    ground_truth = []\\n",
    "\\n",
    "    # 2. Generate Test Positions\\n",
    "    N_POSITIONS = 100\\n",
    "    test_positions = []\\n",
    "    for _ in tqdm(range(N_POSITIONS), desc=\\"Generating Positions\\"):\\n",
    "        n_moves = random.randint(5, 20) # Create positions with some history\\n",
    "        board, player, move_seq = generate_random_state(n_moves)\\n",
    "        test_positions.append((board, player, move_seq))\\n",
    "\\n",
    "    # 3. Run Benchmark\\n",
    "    for board, player, move_seq in tqdm(test_positions, desc=\\"Running Benchmark\\"):\\n",
    "        # Get ground truth move\\n",
    "        correct_move = solved_bot.get_next_best_move(move_seq)\\n",
    "        if correct_move is None:\\n",
    "            continue # Skip if solver fails\\n",
    "        ground_truth.append(correct_move - 1) # Convert to 0-indexed\\n",
    "\\n",
    "        # Get moves from other bots\\n",
    "        for name, bot in bots.items():\\n",
    "            if name == \\"PolicyBot\\":\\n",
    "                action = bot.get_action(board, player) \\n",
    "            else:\\n",
    "                action = bot.get_action(board, player) # AB bots use 0-indexed actions\\n",
    "            results[name].append(action)\\n",
    "\\n",
    "    # 4. Analyze and Plot Results\\n",
    "    for name, bot_moves in results.items():\\n",
    "        if not bot_moves: continue\\n",
    "        acc = accuracy_score(ground_truth, bot_moves)\\n",
    "        print(f\\"--- Results for {name} ---\\")\\n",
    "        print(f\\"Accuracy vs SolvedBot: {acc:.2f}\\")\\n",
    "\\n",
    "        # Confusion Matrix\\n",
    "        cm = confusion_matrix(ground_truth, bot_moves, labels=list(range(7)))\\n",
    "        plt.figure(figsize=(8, 6))\\n",
    "        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=range(1, 8), yticklabels=range(1, 8))\\n",
    "        plt.title(f'Confusion Matrix for {name}')\\n",
    "        plt.xlabel('Predicted Move')\\n",
    "        plt.ylabel('True Move')\\n",
    "        plt.show()\\n",
    "\\n",
    "if __name__ == '__main__':\\n",
    "    run_benchmark()"
   ]
  }
