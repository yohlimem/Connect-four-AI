   "source": [
    "## Test how fast the gpu is against the cpu"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "eec5a60e",
   "metadata": {},
   "outputs": [],
   "source": [
    "from policy import Policy\\n",
    "import torch\\n",
    "\\n",
    "def run_inference_benchmark(device_name, batch_size, num_runs=1000):\\n",
    "    if device_name == \\"cuda\\" and not torch.cuda.is_available():\\n",
    "        print(\\"❌ CUDA not available. Skipping GPU test.\\")\\n",
    "        return 0.0\\n",
    "\\n",
    "    device = torch.device(device_name)\\n",
    "    model = Policy(7, input_channels=2, board_height=6, board_width=7, ent_coef=0.03, conv_layers_channels=[32, 64, 32], fc_layer_sizes=[256, 256, 256]).to(device)\\n",
    "    model.eval() # Inference mode\\n",
    "\\n",
    "    # Create dummy input\\n",
    "    input_data = torch.randn(batch_size, 2, 6, 7).to(device)\\n",
    "\\n",
    "    # Warmup (Wake up the GPU)\\n",
    "    for _ in range(10):\\n",
    "        _ = model(input_data)\\n",
    "    \\n",
    "    # Synchronize before starting timer (Crucial for GPU)\\n",
    "    if device_name == \\"cuda\\":\\n",
    "        torch.cuda.synchronize()\\n",
    "    \\n",
    "    start_time = time.perf_counter()\\n",
    "    \\n",
    "    with torch.no_grad():\\n",
    "        for _ in range(num_runs):\\n",
    "            _ = model(input_data)\\n",
    "            \\n",
    "    # Synchronize after finishing (Crucial for GPU)\\n",
    "    if device_name == \\"cuda\\":\\n",
    "        torch.cuda.synchronize()\\n",
    "\\n",
    "    end_time = time.perf_counter()\\n",
    "    \\n",
    "    avg_time = (end_time - start_time) / num_runs\\n",
    "    print(f\\"[{device_name.upper()}] Batch Size {batch_size}: {avg_time*1000:.4f} ms per pass\\")\\n",
    "    return avg_time\\n"
