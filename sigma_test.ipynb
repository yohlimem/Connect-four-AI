   "source": [
    "env = Connect4Env()\\n",
    "from policy import Policy\\n",
    "from state_value import StateValue\\n",
    "ppo_policy = Policy(env.action_space.n, input_channels=2, board_height=6, board_width=7, ent_coef=0.03) # pyright: ignore[reportOptionalSubscript]\\n",
    "ppo_policy.load_from_file(\\"connect4_cnn_iter_800000.pth\\")\\n",
    "policy_2 = AlphaBetaBot(depth=5)\\n",
    "test_sigma_agent(Connect4Env, policy=ppo_policy, policy_2=policy_2, games=1, visual=True)"
   ]
