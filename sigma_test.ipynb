    "    else:\\n",
    "        print(f\\"  [FAIL] Channel 1 failed. \\n{p1_obs[1]}\\")\\n",
    "\\n",
    "    \\n",
    "    # --- TEST CASE B: Player 2's Perspective (The \\"Flip\\" Test) ---\\n",
    "    print(\\"\\n[TEST B] Player 2's Turn (current_player = -1)\\")\\n",
    "    # To Player 2: \\n",
    "    #   P2 (at 5,1) is \\"Me\\" -> Should be in Channel 0\\n",
