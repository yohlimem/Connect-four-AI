    "def run_training_benchmark(device_name, batch_size=1024, num_runs=50):\\n",
    "    \\"\\"\\"\\n",
    "    Measures how fast the device can perform a full PPO update:\\n",
    "    Forward Pass + Loss Calc + Backward Pass + Optimizer Step\\n",
    "    \\"\\"\\"\\n",
    "    if device_name == \\"cuda\\" and not torch.cuda.is_available():\\n",
    "        print(\\"❌ CUDA not available. Skipping GPU test.\\")\\n",
    "        return 0.0\\n",
    "\\n",
    "    device = torch.device(device_name)\\n",
    "    print(f\\"Preparing Training Benchmark on {device_name.upper()}...\\")\\n",
    "\\n",
    "    # Initialize Policy\\n",
    "    model = Policy(7, input_channels=2, board_height=6, board_width=7, ent_coef=0.03, \\n",
    "                   conv_layers_channels=[32, 64, 32], fc_layer_sizes=[256, 256, 256]).to(device)\\n",
    "    model.train() # Training mode\\n",
    "\\n",
    "    # Create Dummy Batch Data (Simulating a replay buffer)\\n",
    "    # Obs: (Batch, 2, 6, 7)\\n",
    "    obs = torch.randn(batch_size, 2, 6, 7).to(device)\\n",
    "    # Actions: (Batch,) - Random integers 0-6\\n",
    "    actions = torch.randint(0, 7, (batch_size,)).float().to(device)\\n",
    "    # Old Log Probs: (Batch,)\\n",
    "    old_probs = torch.randn(batch_size).to(device)\\n",
    "    # Rewards (Returns): (Batch,)\\n",
    "    rewards = torch.randn(batch_size).to(device)\\n",
    "    # Advantages: (Batch,)\\n",
    "    advantages = torch.randn(batch_size).to(device)\\n",
    "\\n",
    "    # Warmup\\n",
    "    for _ in range(5):\\n",
    "        model.optimizer_step(obs, actions, old_probs, rewards, advantages)\\n",
    "\\n",
    "    if device_name == \\"cuda\\": torch.cuda.synchronize()\\n",
    "    \\n",
    "    start_time = time.perf_counter()\\n",
    "    \\n",
    "    # Run the Loop\\n",
    "    for _ in range(num_runs):\\n",
    "        model.optimizer_step(obs, actions, old_probs, rewards, advantages)\\n",
    "\\n",
    "    if device_name == \\"cuda\\": torch.cuda.synchronize()\\n",
    "\\n",
    "    end_time = time.perf_counter()\\n",
    "    avg_time = (end_time - start_time) / num_runs\\n",
    "    print(f\\"[{device_name.upper()}] Training  (Batch {batch_size}): {avg_time*1000:.4f} ms per step\\")\\n",
    "    return avg_time"
   ]
  },
