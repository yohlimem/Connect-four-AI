    "from policy import Policy\\n",
    "import torch\\n",
    "import time\\n",
    "from connect4 import Connect4Env, preprocess_board\\n",
    "\\n",
    "def benchmark_game_speed(env, policy, device, n_games=1000):\\n",
    "    print(f\\"\\n--- 🏎️  STARTING SPEED BENCHMARK ({n_games} Games) ---\\")\\n",
    "    print(f\\"Device: {device}\\")\\n",
    "    \\n",
    "    # Switch to eval mode (disable dropout, etc. for pure speed)\\n",
    "    policy.eval()\\n",
    "    \\n",
    "    start_time = time.perf_counter()\\n",
    "    total_steps = 0\\n",
    "    \\n",
    "    for i in range(n_games):\\n",
    "        obs, _ = env.reset()\\n",
    "        terminated = False\\n",
    "        \\n",
    "        while not terminated:\\n",
    "            # 1. Preprocess\\n",
    "            current_obs = preprocess_board(obs, env.current_player)\\n",
    "            \\n",
    "            # 2. Inference (GPU)\\n",
    "            with torch.no_grad():\\n",
    "                tensor_input = torch.from_numpy(current_obs).unsqueeze(0).float().to(device)\\n",
    "                \\n",
    "                # Fast Policy Inference\\n",
    "                logits = policy(tensor_input)[0]\\n",
    "                \\n",
    "                # Fast Masking\\n",
    "                mask = torch.tensor([0.0 if env.board[0][c] == 0 else -1e9 for c in range(env.cols)], device=device)\\n",
    "                \\n",
    "                # Greedy action for benchmarking (faster than sampling)\\n",
    "                # or sample if you want realistic simulation\\n",
    "                action = torch.argmax(logits + mask).item() \\n",
    "            \\n",
    "            # 3. Environment Step (Numba Optimized)\\n",
    "            obs, _, terminated, _, _ = env.step(action)\\n",
    "            total_steps += 1\\n",
    "            \\n",
    "    end_time = time.perf_counter()\\n",
    "    duration = end_time - start_time\\n",
    "    \\n",
    "    # --- REPORT CARD ---\\n",
    "    avg_time_per_game = (duration / n_games) * 1000 # in ms\\n",
    "    games_per_sec = n_games / duration\\n",
    "    steps_per_sec = total_steps / duration\\n",
    "    \\n",
    "    print(f\\"--- 🏁 BENCHMARK COMPLETE ---\\")\\n",
    "    print(f\\"Total Time:       {duration:.4f} seconds\\")\\n",
    "    print(f\\"Total Steps:      {total_steps}\\")\\n",
    "    print(f\\"Avg Game Time:    {avg_time_per_game:.2f} ms\\")\\n",
    "    print(\\"-" * 30)\\n",
    "    print(f\\"⚡ Games Per Second: {games_per_sec:.2f}\\")\\n",
    "    print(f\\"⚡ Steps Per Second: {steps_per_sec:.2f}\\")\\n",
    "    \\n",
    "    # The Sigma Verdict\\n",
    "    if games_per_sec > 100:\\n",
    "        print(\\"Verdict: HYPERSONIC. You are ready for massive scale.\\")\\n",
    "    elif games_per_sec > 50:\\n",
    "        print(\\"Verdict: SUPERSONIC. Respectable speed.\\")\\n",
    "    else:\\n",
    "        print(\\"Verdict: SUBSONIC. We might need Vectorized Environments.\\")"
   ]
