   "outputs": [],
   "source": [
    "import numpy as np\\n",
    "import torch\\n",
    "\\n",
    "from connect4 import Connect4Env\\n",
    "from utils import preprocess_board\\n",
    "\\n",
    "from AlphaBetaBot import AlphaBetaBot\\n",
    "\\n",
    "from policy import Policy\\n",
    "\\n",
    "\\n",
    "def test_sigma_agent(env_class, policy = None, policy_2: None|Policy|AlphaBetaBot = None, games=100, visual=False): # (made with gemini)\\n",
    "    env = env_class()\\n",
    "    ai_wins = 0\\n",
    "    \\n",
    "    print(f\\"Running {games} games against other Bot...\\")\\n",
    "    \\n",
    "    for game in range(games):\\n",
    "        obs, _ = env.reset()\\n",
    "        # AI plays as Player 1 (Blue)\\n",
    "        done = False\\n",
    "        \\n",
    "        while not done:\\n",
    "            if env.current_player == 1: # AI Turn\\n",
    "                # AI Logic\\n",
    "                if policy is not None:\\n",
    "                    ai_input = torch.from_numpy(preprocess_board(obs, 1)).float().unsqueeze(0)\\n",
    "                    with torch.no_grad():\\n",
    "                        logits = policy.forward(ai_input)[0]\\n",
    "                        mask = torch.tensor([0.0 if env.board[0][c] == 0 else -1e9 for c in range(env.cols)])\\n",
    "                        action = torch.argmax(logits + mask).item()\\n",
    "                else:\\n",
    "                    print(\\"please give policy to check\\")\\n",
    "                    return\\n",
    "            else: # Random Turn\\n",
    "                if policy_2 is not None and isinstance(policy_2, Policy):\\n",
    "                    ai_input = torch.from_numpy(preprocess_board(obs, -1)).float().unsqueeze(0)\\n",
    "                    with torch.no_grad():\\n",
    "                        logits = policy_2.forward(ai_input)[0]\\n",
    "                        mask = torch.tensor([0.0 if env.board[0][c] == 0 else -1e9 for c in range(env.cols)])\\n",
    "                        action = torch.argmax(logits + mask).item()\\n",
    "                elif policy_2 is not None and isinstance(policy_2, AlphaBetaBot):\\n",
    "                    action = policy_2.get_action(obs, -1)\\n",
    "                    \\n",
    "                else:\\n",
    "                    # Random Logic\\n",
    "                    legal = [c for c in range(env.cols) if env.board[0][c] == 0]\\n",
    "                    action = np.random.choice(legal)\\n",
    "                \\n",
    "            obs, _, done, _, info = env.step(action)\\n",
    "            if visual:\\n",
    "                env.render()\\n",
    "            \\n",
    "        if info['winner'] == 1:\\n",
    "            if visual:\\n",
    "                print(\\"AI Wins!\\")\\n",
    "            ai_wins += 1\\n",
    "            \\n",
    "    print(f\\"Sigma AI Win Rate vs Bot: {ai_wins}/{games} ({ai_wins/games*100}%)\\")\\n",
    "\\n",
    "\\n",
    "\\n",
    "\\n",
    "\\n",
    "\\n",
    "    \\n",
    "\\n",
    "    "
   ]
  },
